# Lab Result Explainer — environment template
# V1 is anonymous and ephemeral: no database, no auth, no third-party services.
# An almost-empty file here is deliberate — do NOT add secrets-bearing services
# to v1 without checking SPEC.md FR-15/FR-16 (privacy promises) first.

# ─── App ──────────────────────────────────────────
# REQUIRED
APP_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info

# ─── Phase 2 (accounts + FHIR) — DO NOT ADD IN V1 ─
# Adding any of these triggers the PHI-grade compliance escalation in SPEC.md NFR-01.
# DATABASE_URL=            # TODO(phase 2): Postgres connection string
# AUTH_SECRET=             # TODO(phase 2): session secret — provider TBD
# FHIR_CLIENT_ID=          # TODO(phase 2): SMART on FHIR app registration, per EHR
# FHIR_REDIRECT_URI=       # TODO(phase 2)
