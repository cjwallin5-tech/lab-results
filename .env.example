# Lab Result Explainer — environment template
# Real values live in .env.local (gitignored). Never commit real values (CLAUDE.md).
# Copy this file to .env.local and fill in the blanks.

# --- Claude API (extraction / drafting) ---
# The single LLM vendor boundary (src/lib/llm.ts). Without this, extraction falls
# back to offline synthetic fixtures — the live path only runs when a key is set
# AND a PDF is uploaded. Get a key at https://console.anthropic.com (Settings → API Keys);
# billing must be enabled. v1 is synthetic data only — never send real PHI.
ANTHROPIC_API_KEY=
# Optional model override; defaults to claude-opus-4-8 when unset.
LLM_MODEL=
# Set to 1 to force the offline synthetic path even when a key is present —
# deterministic and free. The E2E suite sets this itself (playwright.config.ts).
LLM_OFFLINE=

# --- Supabase ---
# Find these in the Supabase dashboard under Project Settings → API.
# With both URL and secret key set, the data layer reads/writes the real database;
# without them it falls back to the in-memory mock, so the app runs with no Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — never NEXT_PUBLIC_, never imported into client code (see src/lib/supabase/server.ts)
SUPABASE_SECRET_KEY=
# Set to 1 to force the in-memory mock even when the Supabase vars are present —
# deterministic seeded data. The E2E suite sets this itself (playwright.config.ts);
# set it in .env.local too if you want to demo against the mock's reports.
DATA_OFFLINE=

# --- Auth / sessions ---
# Signs provider + DOB-gate session cookies. Set a long random value in any real
# environment; an insecure dev-only default is used when unset (fine for local only).
SESSION_SECRET=
# Demo provider login (synthetic account only, FR-01). Falls back to built-in demo
# credentials when unset.
DEMO_PROVIDER_EMAIL=
DEMO_PROVIDER_PASSWORD=
